{
  "name": "Teaclave - Testing async threads inside SGX enclaves",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "REMOTE_USER": "dev",
      "REMOTE_UID": "1010",
      "REMOTE_GID": "1010",
      "NODE_VERSION": "16.20.2",
      "NEOVIM_VERSION": "0.11.4",
      "STORM_VERSION": "2.8.5",
      "GIT_EMAIL": "lucadibello@proton.me",
      "GIT_NAME": "Luca Di Bello",
      "MAVEN_VERSION": "3.9.14"
    }
  },
  "remoteUser": "dev",
  "runArgs": [
    "--name=poc-teaclave-devcontainer",
    "--privileged",
    "--device=/dev/sgx_enclave:/dev/sgx/enclave",
    "--device=/dev/sgx_provision:/dev/sgx/provision",
    "--device=/dev/sgx_vepc:/dev/sgx/vepc",
    "--env-file",
    ".env",
    "--network",
    "storm-net",
    "--publish",
    "127.0.0.1:2223:2222"
  ],
  "overrideCommand": false,
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "forwardPorts": [2223],
  "mounts": [
    "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind"
  ],
  "containerEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "postCreateCommand": "sudo passwd dev"
}
